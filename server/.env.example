# Required: your own Volcengine Ark (火山方舟) API key. This sandbox has no
# usable key for the app itself — you must supply your own to run the AI endpoints.
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: override the model used for all 5 generation endpoints.
# Defaults to doubao-seed-2-1-pro-260628.
ARK_MODEL=doubao-seed-2-1-pro-260628

# Optional: override the Ark API base URL (without trailing /responses).
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

PORT=8787
